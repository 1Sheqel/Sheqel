#!/bin/bash
# SheqelMotion Studio launcher — runs without Terminal

# Go to the folder containing app.py (3 levels up from this script)
APP_DIR="$(cd "$(dirname "$0")/../../.." && pwd)"
cd "$APP_DIR"

# Find Python 3.10+
PYTHON=""
for candidate in python3.12 python3.11 python3.10 python3; do
    if command -v "$candidate" &>/dev/null; then
        PYTHON="$candidate"
        break
    fi
done

if [ -z "$PYTHON" ]; then
    osascript -e 'display alert "Python не найден" message "Установи Python 3.10 или новее с сайта python.org" as critical'
    exit 1
fi

# Install dependencies silently
"$PYTHON" -m pip install -r "$APP_DIR/requirements.txt" --quiet 2>/dev/null

# Launch the app
exec "$PYTHON" "$APP_DIR/app.py"
